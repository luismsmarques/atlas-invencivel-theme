# WordPress Theme Git Ignore File
# Atlas Theme - Version Control Configuration

# =============================================================================
# WordPress Core Files (if accidentally included)
# =============================================================================
wp-config.php
wp-content/uploads/
wp-content/cache/
wp-content/backup-db/
wp-content/backups/
wp-content/blogs.dir/
wp-content/upgrade/
wp-content/uploads/
wp-content/plugins/
wp-content/themes/twenty*/
wp-content/themes/index.php

# =============================================================================
# Development Files
# =============================================================================
# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Package managers
package-lock.json
yarn.lock
composer.lock

# =============================================================================
# IDE and Editor Files
# =============================================================================
# VSCode
.vscode/
*.code-workspace

# Sublime Text
*.sublime-project
*.sublime-workspace

# PhpStorm/WebStorm
.idea/

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# =============================================================================
# OS Generated Files
# =============================================================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# =============================================================================
# Logs and Temporary Files
# =============================================================================
*.log
*.tmp
*.temp
*.cache
*.pid
*.seed
*.pid.lock

# =============================================================================
# Backup Files
# =============================================================================
*.bak
*.backup
*.old
*.orig
*.save
*.swp
*.swo

# =============================================================================
# Compressed Files
# =============================================================================
*.zip
*.tar.gz
*.rar
*.7z

# =============================================================================
# Theme Specific Exclusions
# =============================================================================
# Development tools (keep these in local development)
dev-tools/create-projects.php
dev-tools/sample-project-data.php

# Cache files
*.cache
cache/

# Temporary uploads
temp-uploads/

# =============================================================================
# Security Sensitive Files
# =============================================================================
# Never commit these files
.env
.env.local
.env.production
.env.staging
config.php
secrets.php
*.key
*.pem
*.crt
*.p12

# =============================================================================
# Build and Distribution Files
# =============================================================================
# Build directories
build/
dist/
compiled/

# Minified files (if using build process)
*.min.css
*.min.js

# =============================================================================
# Documentation (optional - uncomment if you don't want docs in repo)
# =============================================================================
# README.md
# CHANGELOG.md
# *.md

# =============================================================================
# Keep Important Files
# =============================================================================
# Always include these important theme files
!style.css
!index.php
!functions.php
!screenshot.png
!readme.txt
!assets/
!inc/
!languages/

# =============================================================================
# cPanel Specific
# =============================================================================
# cPanel backup files
cpanel_backup/
public_html_backup/
error_logs/
access_logs/

# =============================================================================
# Local Development Only (uncomment for production)
# =============================================================================
# Uncomment these lines if deploying to production server
# dev-tools/
# *.md
# deploy.sh
# server-deploy.sh